{
  "version": 2,
  "builds": [
    {
      "src": "qr_utility_app/pubspec.yaml",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "qr_utility_app/build/web",
        "buildCommand": "flutter build web --release"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/qr_utility_app/build/web/$1" }
  ]
}